{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "reachdem-worker-whatsapp",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "find_additional_modules": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": { "enabled": true, "head_sampling_rate": 1, "persist": true }
  },
  "vars": { "WORKER_ENV": "development" },
  "queues": {
    "producers": [
      { "binding": "WHATSAPP_QUEUE", "queue": "reachdem-whatsapp-queue" }
    ],
    "consumers": [
      {
        "queue": "reachdem-whatsapp-queue",
        "max_batch_size": 40,
        "max_batch_timeout": 2,
        "max_concurrency": 5,
        "max_retries": 5
      }
    ]
  },
  "env": {
    "staging": {
      "name": "reachdem-worker-whatsapp-staging",
      "vars": { "WORKER_ENV": "staging" },
      "queues": {
        "producers": [
          {
            "binding": "WHATSAPP_QUEUE",
            "queue": "reachdem-whatsapp-queue-staging"
          }
        ],
        "consumers": [
          {
            "queue": "reachdem-whatsapp-queue-staging",
            "max_batch_size": 40,
            "max_batch_timeout": 2,
            "max_concurrency": 5,
            "max_retries": 5
          }
        ]
      }
    },
    "production": {
      "name": "reachdem-worker-whatsapp",
      "vars": { "WORKER_ENV": "production" },
      "queues": {
        "producers": [
          {
            "binding": "WHATSAPP_QUEUE",
            "queue": "reachdem-whatsapp-queue-v2-production"
          }
        ],
        "consumers": [
          {
            "queue": "reachdem-whatsapp-queue-v2-production",
            "max_batch_size": 40,
            "max_batch_timeout": 2,
            "max_concurrency": 5,
            "max_retries": 5
          }
        ]
      }
    }
  }
}
