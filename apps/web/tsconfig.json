{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "baseUrl": ".",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@reachdem/auth": ["../../packages/auth/src/index.ts"],
      "@reachdem/auth/*": ["../../packages/auth/src/*"],
      "@reachdem/core": ["../../packages/core/src/index.ts"],
      "@reachdem/core/*": ["../../packages/core/src/*"],
      "@reachdem/database": ["../../packages/database/src/index.ts"],
      "@reachdem/database/*": ["../../packages/database/src/*"],
      "@reachdem/email-ui": ["../../packages/email-ui/src/index.ts"],
      "@reachdem/email-ui/*": ["../../packages/email-ui/src/*"],
      "@reachdem/shared": ["../../packages/shared/src/index.ts"],
      "@reachdem/shared/*": ["../../packages/shared/src/*"],
      "@reachdem/transactional": ["../../packages/transactional/index.ts"],
      "@reachdem/transactional/*": ["../../packages/transactional/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "**/__tests__/**"]
}
