# Alibaba Cloud Direct Mail Configuration
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_REGION=

# Verified Email Address on Alibaba Cloud
ALIBABA_SENDER_EMAIL=
ALIBABA_SENDER_NAME=

# SMTP Credentials (if needed for backup)
SMTP_USER=
SMTP_PASSWORD=

# Flutterwave payment API
## Flutterwave is the active checkout provider for ReachDem.
## Optional: set payment options explicitly, for example:
## FLUTTERWAVE_PAYMENT_OPTIONS=card,banktransfer,ussd,mobilemoneyghana,mobilemoneyuganda,mpesa
FLUTTERWAVE_PUB_KEY_V3=
FLUTTERWAVE_V4_BASE_URL=
FLUTTERWAVE_V4_CLIENT_ID=
FLUTTERWAVE_V4_CLIENT_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET_HASH=
FLUTTERWAVE_PAYMENT_OPTIONS=

# Stripe payment API (legacy / disabled for new checkout sessions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Payment pricing / return URLs
PAYMENT_RETURN_URL=
PAYMENT_DEFAULT_CURRENCY=XAF
PAYMENT_PLAN_BASIC_AMOUNT_MINOR=
PAYMENT_PLAN_STARTER_AMOUNT_MINOR=
PAYMENT_PLAN_GROWTH_AMOUNT_MINOR=
PAYMENT_PLAN_PRO_AMOUNT_MINOR=
PAYMENT_PLAN_SCALE_AMOUNT_MINOR=
