API_DEFAULT_EMAIL_TIERS_JSON='[{"minimumQuantity":1,"unitAmountMinor":7},{"minimumQuantity":10001,"unitAmountMinor":5},{"minimumQuantity":50001,"unitAmountMinor":4},{"minimumQuantity":200001,"unitAmountMinor":3}]'
