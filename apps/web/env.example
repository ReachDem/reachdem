PAYMENT_CREDIT_VOLUME_DISCOUNT_UNIT_AMOUNT_MINOR=16
PAYMENT_CREDIT_MINIMUM_QUANTITY=250
PAYMENT_CREDIT_SUGGESTED_QUANTITIES=250,500,1000
MESSAGE_SMS_UNIT_AMOUNT_MINOR=25
MESSAGE_EMAIL_UNIT_AMOUNT_MINOR=7
API_KEY_HASH_SECRET=
API_IDEMPOTENCY_TTL_SECONDS=86400
