{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@reachdem/core": ["./types/reachdem-core-shim.d.ts"],
      "@reachdem/database": ["./types/reachdem-database-shim.d.ts"]
    }
  },
  "include": [
    "fixtures/**/*.ts",
    "lib/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "app"]
}
