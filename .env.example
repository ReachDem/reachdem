# Database Configuration
DATABASE_URL=
# Optional: Prisma Accelerate URL (when using Accelerate instead of direct adapter)
PRISMA_ACCELERATE_URL=

# Better Auth Configuration
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Optional dedicated secret for encrypting visible workspace API keys
API_KEY_ENCRYPTION_SECRET=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LINKS_URL=http://localhost:3001

# Auth cookie domain (use ".reachdem.cc" in production, omit for localhost)
AUTH_COOKIE_DOMAIN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Alibaba Cloud Direct Mail
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_REGION=
ALIBABA_SENDER_EMAIL=
ALIBABA_SENDER_NAME=

# Resend (Email)
RESEND_API_KEY=

# Google Fonts API (Optional - for font selector in email composer)
# Get your API key from: https://developers.google.com/fonts/docs/developer_api
GOOGLE_FONTS_API_KEY=
