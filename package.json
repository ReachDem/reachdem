{
  "name": "reachdem-monorepo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "sync-env": "node sync-env.js",
    "predev": "pnpm sync-env",
    "dev": "pnpm --filter reachdem-main dev",
    "dev:links": "pnpm --filter links dev",
    "dev:all": "pnpm --filter reachdem-main --filter links dev",
    "build": "pnpm --filter reachdem-main build",
    "build:links": "pnpm --filter links build",
    "db:generate": "pnpm --filter @reachdem/database db:generate",
    "db:push": "pnpm --filter @reachdem/database db:push",
    "db:migrate": "pnpm --filter @reachdem/database db:migrate",
    "db:studio": "pnpm --filter @reachdem/database db:studio",
    "backfill:api-keys": "dotenv -e .env -- tsx scripts/backfill-default-api-keys.ts",
    "link-campaign-stats": "tsx scripts/link-campaign-stats.ts",
    "workers:types": "pnpm -r --filter @reachdem/worker-email --filter @reachdem/worker-sms --filter @reachdem/worker-whatsapp --filter @reachdem/worker-campaign --filter @reachdem/worker-scheduler types",
    "workers:check": "pnpm -r --filter @reachdem/worker-email --filter @reachdem/worker-sms --filter @reachdem/worker-whatsapp --filter @reachdem/worker-campaign --filter @reachdem/worker-scheduler check",
    "workers:test": "pnpm -r --filter @reachdem/jobs --filter @reachdem/worker-kit --filter @reachdem/worker-email --filter @reachdem/worker-sms --filter @reachdem/worker-whatsapp --filter @reachdem/worker-campaign --filter @reachdem/worker-scheduler test",
    "workers:deploy:staging": "node scripts/workers-deploy-and-sync.mjs --env staging",
    "workers:deploy:production": "node scripts/workers-deploy-and-sync.mjs --env production",
    "workers:secrets:staging": "node scripts/workers-sync-secrets.mjs --env staging",
    "workers:secrets:production": "node scripts/workers-sync-secrets.mjs --env production",
    "workers:env:audit": "node scripts/workers-env-audit.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@next/env": "^15.5.12",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^7.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "magicast": "^0.5.2",
    "next": "16.2.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.20.6",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@prisma/config": "^7.4.2",
    "@react-email/components": "^1.0.8"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,md,json,css}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "@react-email/editor>@tiptap/core": "3.22.5",
      "@react-email/editor>@tiptap/pm": "3.22.5",
      "@react-email/editor>@tiptap/react": "3.22.5"
    }
  }
}
