{
  "name": "reachdem-monorepo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "sync-env": "node sync-env.js",
    "predev": "pnpm sync-env",
    "dev": "pnpm --filter reachdem-main dev",
    "dev:links": "pnpm --filter links dev",
    "dev:all": "pnpm --filter reachdem-main --filter links dev",
    "build": "pnpm --filter reachdem-main build",
    "build:links": "pnpm --filter links build",
    "db:generate": "pnpm --filter @reachdem/database db:generate",
    "db:push": "pnpm --filter @reachdem/database db:push",
    "db:migrate": "pnpm --filter @reachdem/database db:migrate",
    "db:studio": "pnpm --filter @reachdem/database db:studio",
    "backfill:api-keys": "dotenv -e .env -- tsx scripts/backfill-default-api-keys.ts",
    "link-campaign-stats": "tsx scripts/link-campaign-stats.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@next/env": "^15.5.12",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^7.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "magicast": "^0.5.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@prisma/config": "^7.4.2",
    "@react-email/components": "^1.0.8"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,md,json,css}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  }
}
