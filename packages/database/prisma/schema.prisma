// This is your Prisma schema file
// Better-Auth compatible schema with Organization plugin

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth Core Models ──────────────────────────────────────────────────

model User {
  id                    String   @id
  name                  String
  email                 String   @unique
  emailVerified         Boolean  @default(false)
  image                 String?
  role                  String? // Added for new onboarding flow
  defaultOrganizationId String? // Added for new onboarding flow
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  members     Member[]
  invitations Invitation[]
  paymentSessions     PaymentSession[]     @relation("PaymentSessionInitiator")
  paymentTransactions PaymentTransaction[] @relation("PaymentTransactionInitiator")

  @@map("user")
}

model Session {
  id                   String   @id
  token                String   @unique
  userId               String
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  activeOrganizationId String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [activeOrganizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── Better Auth Organization Plugin Models ───────────────────────────────────

model Organization {
  id        String   @id
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  members        Member[]
  invitations    Invitation[]
  sessions       Session[]
  contacts       Contact[]
  contactFields  ContactFieldDefinition[]
  groups         Group[]
  segments       Segment[]
  activityEvents ActivityEvent[]
  smsConfig      WorkspaceSmsConfig?
  messages       Message[]
  campaigns      Campaign[]
  trackedLinks   TrackedLink[]
  paymentSessions     PaymentSession[]
  paymentTransactions PaymentTransaction[]
  billingState   WorkspaceBillingState?

  @@map("organization")
}

model Member {
  id             String   @id
  organizationId String
  userId         String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String   @id
  organizationId String
  email          String
  role           String   @default("member")
  status         String   @default("pending")
  expiresAt      DateTime
  inviterId      String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Gender {
  UNKNOWN
  MALE
  FEMALE
  OTHER
}

enum ContactFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  URL
  SELECT
}

// ─── ReachDem App Models ──────────────────────────────────────────────────────

model ContactFieldDefinition {
  id             String           @id @default(uuid())
  organizationId String
  key            String
  label          String
  type           ContactFieldType
  options        Json? // Array of strings if type is SELECT
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("contact_field_definition")
}

model Contact {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  phoneE164      String?
  email          String?
  gender         Gender?   @default(UNKNOWN)
  birthdate      DateTime? @db.Date // Only store date component
  address        String?
  work           String?
  enterprise     String?
  customFields   Json? // Map of key to value
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // Soft delete

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     GroupMember[]
  campaignTargets CampaignTarget[]
  trackedLinks    TrackedLink[]

  @@index([organizationId])
  @@index([phoneE164])
  @@index([email])
  @@map("contact")
}

model Group {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      GroupMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("group")
}

model GroupMember {
  groupId   String
  contactId String
  addedAt   DateTime @default(now())

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([groupId, contactId])
  @@index([contactId])
  @@map("group_member")
}

model Segment {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  definition     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("segment")
}

// ─── Activity Log Enums ───────────────────────────────────────────────────────

enum ActorType {
  user
  system
  api_key
}

enum EventCategory {
  sms
  email
  whatsapp
  contacts
  links
  auth
  billing
  system
}

enum EventAction {
  send_attempt
  send_success
  send_failed
  fallback
  provider_error
  rate_limit
  created
  updated
  deleted
}

enum ResourceType {
  message
  campaign
  segment
  group
  contact
  webhook
}

enum EventSeverity {
  debug
  info
  warn
  error
}

enum EventStatus {
  success
  failed
  pending
}

// ─── Activity Log Models ──────────────────────────────────────────────────────

model ActivityEvent {
  id                String        @id @default(uuid())
  organizationId    String
  actorType         ActorType     @default(system)
  actorId           String? // User ID or service name
  category          EventCategory
  action            EventAction
  resourceType      ResourceType?
  resourceId        String?
  provider          String? // e.g. twilio, infobip, sendgrid
  providerRequestId String? // Provider-side message/request ID
  correlationId     String // Stable across a full chain (auto-generated if absent)
  idempotencyKey    String?
  severity          EventSeverity @default(info)
  status            EventStatus
  durationMs        Int?
  meta              Json? // JSONB: error codes, fallback info, redacted payloads
  expiresAt         DateTime? // For future retention/archival policy
  createdAt         DateTime      @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerCalls ProviderCall[]

  @@index([organizationId])
  @@index([correlationId])
  @@index([organizationId, createdAt])
  @@index([organizationId, category, createdAt])
  @@index([organizationId, provider, createdAt])
  @@map("activity_event")
}

model ProviderCall {
  id              String   @id @default(uuid())
  organizationId  String
  activityEventId String
  provider        String // e.g. twilio, infobip
  endpoint        String // Path only, no sensitive IDs (e.g. /2010-04-01/Accounts/***/Messages)
  method          String // GET, POST, etc.
  requestMeta     Json? // Redacted request details (never raw PII)
  responseMeta    Json? // Redacted response details
  httpStatus      Int?
  errorCode       String?
  errorMessage    String? // Truncated (max 500 chars)
  durationMs      Int
  createdAt       DateTime @default(now())

  activityEvent ActivityEvent @relation(fields: [activityEventId], references: [id], onDelete: Cascade)

  @@index([activityEventId])
  @@index([organizationId, createdAt])
  @@map("provider_call")
}

// ─── SMS Messaging Models ─────────────────────────────────────────────────────

enum SmsProvider {
  twilio
  infobip
  lmt
  mboaSms
  avlytext
  stub
}

enum MessageChannel {
  sms
  email
}

enum MessageStatus {
  scheduled
  queued
  sending
  sent
  failed
}

enum AttemptStatus {
  queued
  sent
  failed
}

model WorkspaceSmsConfig {
  id                 String        @id @default(uuid())
  organizationId     String        @unique
  primaryProvider    SmsProvider
  secondaryProviders SmsProvider[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("workspace_sms_config")
}

model Message {
  id               String         @id @default(cuid())
  organizationId   String
  campaignId       String?
  channel          MessageChannel @default(sms)
  toEmail          String?
  toE164           String?
  toHashed         String // SHA-256 of full E.164 number
  toLast4          String // Last 4 digits for display/debug
  from             String // Sender ID
  subject          String?
  text             String? // Content (in clear for MVP)
  html             String?
  status           MessageStatus  @default(queued)
  providerSelected String? // Name of the winning provider
  correlationId    String         @default(uuid())
  idempotencyKey   String
  scheduledAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attempts     MessageAttempt[]
  trackedLinks  TrackedLink[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, createdAt])
  @@index([organizationId, campaignId])
  @@index([organizationId, status])
  @@index([organizationId, channel, status, scheduledAt])
  @@map("message")
}

model MessageAttempt {
  id                String        @id @default(uuid())
  messageId         String
  organizationId    String
  provider          String
  attemptNo         Int
  status            AttemptStatus
  providerMessageId String?
  errorCode         String?
  errorMessage      String? // Truncated (max 500 chars)
  durationMs        Int
  createdAt         DateTime      @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([organizationId, createdAt])
  @@map("message_attempt")
}

// ─── Campaigns ──────────────────────────────────────────────────────────────

enum CampaignStatus {
  draft
  running
  partial
  completed
  failed
}

enum CampaignChannel {
  sms
  email
}

enum TrackedLinkStatus {
  active
  disabled
}

enum PaymentKind {
  subscription
  creditPurchase
}

enum PaymentProvider {
  flutterwave
  stripe
}

enum PaymentSessionStatus {
  pending
  providerRedirected
  processing
  succeeded
  failed
  cancelled
  expired
}

enum PaymentTransactionStatus {
  initiated
  pending
  processing
  succeeded
  failed
  cancelled
  refunded
}

enum AudienceSourceType {
  group
  segment
}

enum TargetStatus {
  pending
  sent
  failed
  skipped
}

model Campaign {
  id             String          @id @default(uuid())
  organizationId String
  name           String
  description    String?
  channel        CampaignChannel @default(sms)
  status         CampaignStatus  @default(draft)
  content        Json
  scheduledAt    DateTime?
  createdBy      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  audiences    CampaignAudience[]
  targets      CampaignTarget[]
  trackedLinks TrackedLink[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("campaign")
}

model CampaignAudience {
  id             String             @id @default(uuid())
  campaignId     String
  organizationId String
  sourceType     AudienceSourceType
  sourceId       String // ID of the Group or Segment

  createdAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, sourceType, sourceId])
  @@index([campaignId])
  @@map("campaign_audience")
}

model CampaignTarget {
  id             String       @id @default(uuid())
  campaignId     String
  organizationId String
  contactId      String
  resolvedTo     String // Hashed phone E.164
  status         TargetStatus @default(pending)
  messageId      String? // Reference to the actual sent Message (nullable)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Note: We don't define a strict relation to Message to avoid circular dependencies
  // or cascade issues, it's just a reference ID.

  @@unique([campaignId, contactId]) // Prevent duplicate targets in the same campaign
  @@index([campaignId, status])
  @@index([organizationId, contactId])
  @@map("campaign_target")
}

model TrackedLink {
  id              String            @id @default(uuid())
  organizationId  String
  sinkLinkId      String
  slug            String
  shortUrl        String
  targetUrl       String
  campaignId      String?
  messageId       String?
  contactId       String?
  channel         MessageChannel?
  status          TrackedLinkStatus @default(active)
  totalClicks     Int?
  uniqueClicks    Int?
  lastStatsSyncAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@unique([organizationId, slug])
  @@unique([sinkLinkId])
  @@index([organizationId, createdAt])
  @@index([organizationId, campaignId])
  @@index([organizationId, messageId])
  @@index([organizationId, contactId])
  @@map("tracked_link")
}

model PaymentSession {
  id                  String               @id @default(uuid())
  organizationId      String
  initiatedByUserId   String
  kind                PaymentKind
  providerPrimary     PaymentProvider
  providerSelected    PaymentProvider?
  status              PaymentSessionStatus @default(pending)
  currency            String
  amountMinor         Int
  planCode            String?
  creditsQuantity     Int?
  providerCheckoutUrl String?
  providerSessionId   String?
  providerReference   String?
  metadata            Json?
  activatedAt         DateTime?
  failedAt            DateTime?
  cancelledAt         DateTime?
  expiredAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  initiatedBy  User                  @relation("PaymentSessionInitiator", fields: [initiatedByUserId], references: [id], onDelete: Restrict)
  transactions PaymentTransaction[]

  @@index([organizationId, status])
  @@index([organizationId, kind, createdAt])
  @@index([organizationId, initiatedByUserId])
  @@index([providerSelected, status])
  @@map("payment_session")
}

model PaymentTransaction {
  id                    String                   @id @default(uuid())
  paymentSessionId      String
  organizationId        String
  initiatedByUserId     String?
  provider              PaymentProvider
  status                PaymentTransactionStatus @default(initiated)
  amountMinor           Int
  currency              String
  providerTransactionId String?
  providerSessionId     String?
  providerReference     String?
  providerEventId       String?
  rawStatus             String?
  rawPayload            Json?
  confirmedAt           DateTime?
  failedAt              DateTime?
  cancelledAt           DateTime?
  refundedAt            DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  paymentSession PaymentSession @relation(fields: [paymentSessionId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  initiatedBy    User?          @relation("PaymentTransactionInitiator", fields: [initiatedByUserId], references: [id], onDelete: SetNull)

  @@index([paymentSessionId, createdAt])
  @@index([organizationId, provider, status])
  @@index([provider, providerReference])
  @@index([provider, providerTransactionId])
  @@index([provider, providerEventId])
  @@map("payment_transaction")
}

model PaymentWebhookEvent {
  id                String          @id @default(uuid())
  provider          PaymentProvider
  providerEventId   String?
  providerReference String?
  providerSignature String?
  signatureValid    Boolean         @default(false)
  processed         Boolean         @default(false)
  processedAt       DateTime?
  rawPayload        Json
  receivedAt        DateTime        @default(now())

  @@index([provider, providerReference])
  @@index([provider, receivedAt])
  @@index([provider, processed])
  @@unique([provider, providerEventId])
  @@map("payment_webhook_event")
}

model WorkspaceBillingState {
  id                   String   @id @default(uuid())
  organizationId       String   @unique
  currentPlanCode      String?
  creditsBalance       Int      @default(0)
  lastPaymentSessionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, currentPlanCode])
  @@map("workspace_billing_state")
}
